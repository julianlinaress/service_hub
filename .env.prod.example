PHOENIX_IMAGE=ghcr.io/julianlinaress/service_hub:sha-<commit>
NOTIFIER_IMAGE=ghcr.io/julianlinaress/service_hub_notifier:sha-<commit>

INTERNAL_SERVICE_TOKEN=replace-with-strong-shared-token

DATABASE_URL=ecto://USER:PASS@HOST/DATABASE
SECRET_KEY_BASE=replace-with-mix-phx-gen-secret
PHX_HOST=example.com
GITHUB_OAUTH_CLIENT_ID=replace-me
GITHUB_OAUTH_CLIENT_SECRET=replace-me

POOL_SIZE=10
NOTIFIER_TIMEOUT_MS=5000
